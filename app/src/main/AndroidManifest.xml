<?xml version="1.0" encoding="utf-8"?>
<!--
  App entry-point manifest.
  
  Per AGENT.md §109: Hilt, Navigation, MainActivity live here.
  Per AGENT.md §404: native lib (libtermux.so) loaded from :terminal module.
  
  Declared permissions / features are minimal for the project setup commit.
  Each phase will add or relax permissions as needed (foreground service for
  persistent terminal sessions, biometric for SSH key vault, notifications for
  command finished events, etc.).

  No Application / Activity classes are declared at this commit - those are
  introduced in Phase 1 alongside the first real UI surface.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Minimal baseline permissions — Phase 1 only. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Iris Shell targets Android 8.0+ but is optimized for Android 16. -->
    <uses-feature
        android:name="android.software.terminal"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.IrisShell"
        tools:targetApi="36" />

</manifest>
